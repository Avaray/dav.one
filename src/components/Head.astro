---
import globalCss from '@/styles/global.css?inline';

import PostHogScript from './PostHogScript.astro';
import CloudflareAnalytics from './CloudflareAnalytics.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  ignoreGlobalStyles?: boolean;
}

const isProduction = String(import.meta.env.PRODUCTION_BUILD) === 'true';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image, ignoreGlobalStyles = false } = Astro.props;
const absoluteImageUrl = image && new URL(image, Astro.site).toString();

{
  /* I need to make this better in the future */
}
const ogType = Astro.url.pathname === '/' ? 'website' : 'article';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': new URL('/#website', Astro.site).toString(),
      url: Astro.site?.toString(),
      name: 'dav.one',
      author: {
        '@type': 'Person',
        '@id': new URL('/#person', Astro.site).toString(),
        name: 'Dawid Wasowski',
        url: new URL('/about-me/', Astro.site).toString(),
      },
    },
    {
      '@type': 'WebPage',
      '@id': canonicalURL.toString(),
      url: canonicalURL.toString(),
      name: title,
      description: description,
      isPartOf: {
        '@id': new URL('/#website', Astro.site).toString(),
      },
    },
  ],
};
---

<head>
  {/* Global Metadata */}
  <meta charset='utf-8' />
  <meta name='viewport' content='width=device-width,initial-scale=1' />
  <link rel='icon' type='image/png' href='/favicon.png' />
  <meta name='generator' content={Astro.generator} />

  {/* Conditionally load global styles */}
  {!ignoreGlobalStyles && <style set:html={globalCss} />}

  {/* Prevent indexing on non-main branches */}
  {!isProduction && <meta name='robots' content='noindex, nofollow' />}

  {/* Canonical URL */}
  {isProduction && <link rel='canonical' href={canonicalURL} />}

  {/* Primary Meta Tags */}
  <title>{title}</title>
  <meta name='title' content={title} />
  <meta name='description' content={description} />

  {/* Open Graph */}
  <meta property='og:title' content={title} />
  <meta property='og:description' content={description} />
  <meta property='og:url' content={canonicalURL} />
  <meta property='og:type' content={ogType} />
  <meta property='og:locale' content='en_US' />
  <meta property='og:site_name' content='dav.one' />
  {absoluteImageUrl && <meta property='og:image' content={absoluteImageUrl} />}

  {/* Twitter */}
  <meta name='twitter:card' content={absoluteImageUrl ? 'summary_large_image' : 'summary'} />
  <meta name='twitter:title' content={title} />
  <meta name='twitter:description' content={description} />
  {absoluteImageUrl && <meta name='twitter:image' content={absoluteImageUrl} />}

  {/* PostHog Web Analytics */}
  {isProduction && <PostHogScript />}

  {/* Cloudflare Web Analytics */}
  {isProduction && <CloudflareAnalytics />}

  {/* Base JSON-LD */}
  <script type='application/ld+json' set:html={JSON.stringify(schema)} />

  {/* Slot */}
  <slot />
</head>
