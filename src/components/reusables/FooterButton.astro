---
import Icon from '@xtreat/astro-iconify';

interface Props {
  href: string;
  text: string;
  icon: string;
  class?: string;
  target?: string;
}

const { href, text, icon, class: className, ...props } = Astro.props;
const { pathname } = Astro.url;
const isActive = href === pathname || href === pathname.replace(/\/$/, '');
---

<a
  href={href}
  class:list={[
    className,
    { active: isActive },
    isActive && 'text-clampography-link',
    'inline-flex flex-col items-center justify-center transition-colors',
  ]}
  {...props}
>
  <Icon
    icon={icon}
    class:list={['h-[2.5em] w-[2.5em]', isActive ? 'text-clampography-link' : 'text-clampography-text']}
  />
  <p class='mt-1 text-center'>{text}</p>
</a>
