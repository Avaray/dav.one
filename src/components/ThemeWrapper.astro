<!doctype html>
<html lang="en" class="transition-colors duration-500">
  {/* Set the initial theme */}
  <script is:inline>
    const currentTheme = localStorage.getItem("theme") || "light";
    document.documentElement.setAttribute("data-theme", currentTheme);
  </script>
  {/* Render the content */}
  <slot />
</html>
