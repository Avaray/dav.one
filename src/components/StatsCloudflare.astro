---
import HeadingWithIcon from './reusables/HeadingWithIcon.astro';
import Alert from './reusables/Alert.astro';
import { calculateAverageNumber, calculatePercentageOf } from '@scripts/utils.ts';
import Stat from './reusables/Stat.astro';
import Icon from '@xtreat/astro-iconify';

const isProduction = String(import.meta.env.PRODUCTION_BUILD) === 'true';

export const isDrop = (previous: number[], current: number) => {
  const previousAverage = calculateAverageNumber(previous);
  return calculatePercentageOf(current, previousAverage, true) < 90;
};

const formatNumber = (num: number): string => {
  if (num >= 1000000) {
    return (num / 1000000).toFixed(1) + 'M';
  } else if (num >= 1000) {
    return (num / 1000).toFixed(1) + 'k';
  }
  return num.toString();
};

const CLOUDFLARE_GRAPHQL_URL = 'https://api.cloudflare.com/client/v4/graphql';
const ZONE_ID = import.meta.env.CF_ZONE_ID;
const API_TOKEN = import.meta.env.CF_RADAR_TOKEN;

const generateMockData = () => {
  const dailyData = [];
  const currentDate = new Date();

  for (let i = 29; i >= 0; i--) {
    const date = new Date();
    date.setDate(currentDate.getDate() - i - 1);
    const formattedDate = date.toISOString().split('T')[0];

    dailyData.push({
      date: formattedDate,
      pageViews: Math.floor(Math.random() * 3000) + 1000,
      requests: Math.floor(Math.random() * 5000) + 2000,
      uniques: Math.floor(Math.random() * 2000) + 500,
    });
  }

  const totalUniques = dailyData.reduce((sum, day) => sum + day.uniques, 0);
  const totalRequests = dailyData.reduce((sum, day) => sum + day.requests, 0);
  const totalBytes = Math.floor(Math.random() * 10000000000) + 5000000000;

  return { dailyData, totalUniques, totalRequests, totalBytes };
};

const fetchCloudflareStats = async () => {
  const currentDate = new Date();
  const thirtyDaysAgo = new Date();
  // Using 31 days because I don't want current day
  thirtyDaysAgo.setDate(currentDate.getDate() - 31);

  // const formattedCurrentDate = currentDate.toISOString().split('T')[0];
  const formattedThirtyDaysAgo = thirtyDaysAgo.toISOString().split('T')[0];

  const headers = {
    'Content-Type': 'application/json',
    Authorization: `Bearer ${API_TOKEN}`,
  };

  // https://pages.johnspurlock.com/graphql-schema-docs/cloudflare.html#AccountHttpRequests1dGroupsSum
  const dailyResponse = await fetch(CLOUDFLARE_GRAPHQL_URL, {
    method: 'POST',
    headers: headers,
    body: JSON.stringify({
      query: `
          query GetDailyStats($zoneId: String!, $since: ISO8601DateTime!) {
            viewer {
              zones(filter: { zoneTag: $zoneId }) {
                totals: httpRequests1dGroups(
                  filter: { date_gt: $since },
                  limit: 30
                ) {
                  uniq { uniques }
                  sum { requests bytes }
                }
                httpRequests1dGroups(
                  filter: { date_gt: $since },
                  limit: 30,
                  orderBy: [date_ASC]
                ) {
                  dimensions { date }
                  uniq { uniques }
                  sum { pageViews requests }
                }
              }
            }
          }
        `,
      variables: {
        zoneId: ZONE_ID,
        since: formattedThirtyDaysAgo,
      },
    }),
  });

  if (!dailyResponse.ok) {
    throw new Error(`HTTP error! Daily: ${dailyResponse.status}`);
  }

  const data = await dailyResponse.json();

  try {
    if (!data.data || data.errors) {
      throw new Error(data.errors ? `GraphQL Error: ${data.errors[0]?.message}` : 'No data returned from API');
    }
    const zoneData = data.data.viewer.zones[0];
    const totalUniques = zoneData.totals[0]?.uniq?.uniques || 0;
    const totalRequests = zoneData.totals[0]?.sum?.requests || 0;
    const totalBytes = zoneData.totals[0]?.sum?.bytes || 0;
    const dailyData = zoneData.httpRequests1dGroups.map((day: any) => {
      return {
        date: day.dimensions.date,
        pageViews: day.sum.pageViews,
        requests: day.sum.requests,
        uniques: day.uniq.uniques,
      };
    });

    return { dailyData, totalUniques, totalRequests, totalBytes };
  } catch (error) {
    console.log(`Can't fetch Cloudflare stats: ${error}`);
    return { dailyData: [], totalUniques: 0, totalRequests: 0, totalBytes: 0 };
  }
};

const {
  dailyData: data30Days,
  totalUniques,
  totalRequests,
  totalBytes,
} = isProduction ? await fetchCloudflareStats() : generateMockData();

const totalBandwidthGB = (totalBytes / (1024 * 1024 * 1024)).toFixed(2);

const highestVisitorsCount = data30Days.reduce(
  (maxObj: any, currentObj: any) => {
    return currentObj.uniques > maxObj.uniques ? currentObj : maxObj;
  },
  { date: '', pageViews: 0, requests: 0, uniques: 0 },
);

const generatedAt = new Date().toISOString();
---

<div
  id='cloudflare-stats-container'
  class='border rounded-2xl w-full p-4 select-none my-8'
  data-generated-at={generatedAt}
>
  <div class='flex flex-col md:flex-row md:justify-between md:items-start'>
    <HeadingWithIcon icon='icon-park-outline:analysis' title="Cloudflare's Monthly Statistics" level={3} />

    <div class='hidden md:flex gap-6 md:gap-8'>
      <div class='text-center'>
        <h3 id='cf-total-uniques' class='font-bold mb-0 text-clampography-success'>
          {formatNumber(totalUniques)}
        </h3>
        <small class='text-clampography-text/90'>Unique visitors</small>
      </div>
      <div class='text-center'>
        <h3 id='cf-total-requests' class='font-bold mb-0 text-clampography-success'>
          {formatNumber(totalRequests)}
        </h3>
        <small class='text-clampography-text/90'>Total requests</small>
      </div>
    </div>
  </div>

  <div id='cf-chart-container' class='hidden md:flex w-full h-24 gap-1 mb-1 mt-8 items-end'>
    {
      data30Days.map((day: any, index: number) => {
        // Get the previous three days, ensuring we do not go out of bounds
        const previousDays = data30Days.slice(Math.max(index - 3, 0), index);
        const previousDay = index > 0 ? data30Days[index - 1] : null;
        const isSpike = previousDay !== null && day.uniques > previousDay.uniques * 1.33;

        const conditionalClasses = [
          index === 0 ? 'sm:rounded-bl-xl' : '',
          index === data30Days.length - 1 ? 'sm:rounded-br-xl' : '',
          isDrop(
            previousDays.map((d: any) => d.uniques),
            day.uniques,
          )
            ? 'bg-clampography-error'
            : 'bg-clampography-success',
        ]
          .filter(Boolean)
          .join(' ');

        return (
          <div
            class={`chart-bar ${conditionalClasses}`}
            style={`--bar-height: calc(20px + ${calculatePercentageOf(day.uniques, highestVisitorsCount.uniques, true)}%)`}
            title={`${day.date}\n\n${day.pageViews} page views\n${day.uniques} unique visitors`}
          >
            {isSpike && (
              <Icon
                icon='material-symbols:fitbit-arrow-upward'
                class='w-full h-auto shrink-0 text-clampography-background'
              />
            )}
          </div>
        );
      })
    }
  </div>

  <!-- Display above "md" media query -->
  <div class='hidden md:flex justify-between'>
    {
      data30Days.length > 0 && (
        <>
          <small id='cf-date-start' class='px-1 text-clampography-text/90'>
            {data30Days[0].date}
          </small>
          <small id='cf-date-end' class='px-1 text-clampography-text/90'>
            {data30Days[data30Days.length - 1].date}
          </small>
        </>
      )
    }
  </div>

  <!-- Display below "md" media query -->
  <div class='md:hidden mt-4 grid grid-cols-2 md:grid-cols-4 gap-4'>
    <Stat id='cf-mobile-total-uniques' value={formatNumber(totalUniques)} label='Unique Visitors' />
    <Stat
      id='cf-mobile-max-uniques'
      value={formatNumber(highestVisitorsCount.uniques)}
      label='Maximum Daily Visitors'
    />
    <Stat id='cf-mobile-total-requests' value={formatNumber(totalRequests)} label='Total Requests' />
    <Stat id='cf-mobile-total-bandwidth' value={`${totalBandwidthGB} GB`} label='Total Bandwidth' />
  </div>
</div>

<script>
  import { calculateAverageNumber, calculatePercentageOf } from '@scripts/utils.ts';

  const formatNumber = (num: number): string => {
    if (num >= 1000000) {
      return (num / 1000000).toFixed(1) + 'M';
    } else if (num >= 1000) {
      return (num / 1000).toFixed(1) + 'k';
    }
    return num.toString();
  };

  const isDrop = (previous: number[], current: number) => {
    const previousAverage = calculateAverageNumber(previous);
    return calculatePercentageOf(current, previousAverage, true) < 90;
  };

  const initCloudflareStats = async () => {
    const container = document.getElementById('cloudflare-stats-container');
    if (!container) return;

    const generatedAtStr = container.getAttribute('data-generated-at');
    if (!generatedAtStr) return;

    const generatedAt = new Date(generatedAtStr).getTime();
    const now = Date.now();
    const hoursDifference = (now - generatedAt) / (1000 * 60 * 60);

    if (hoursDifference > 24) {
      try {
        const response = await fetch('/cloudflare-stats.json');
        if (!response.ok) throw new Error('Failed to fetch new stats');

        const data = await response.json();

        const totalBandwidthGB = (data.totalBytes / (1024 * 1024 * 1024)).toFixed(2);
        const highestVisitorsCount = data.dailyData.reduce(
          (maxObj: any, currentObj: any) => {
            return currentObj.uniques > maxObj.uniques ? currentObj : maxObj;
          },
          { date: '', pageViews: 0, requests: 0, uniques: 0 },
        );

        const updateEl = (id: string, text: string) => {
          const el = document.getElementById(id);
          if (el) el.innerText = text;
        };

        // Desktop stats
        updateEl('cf-total-uniques', formatNumber(data.totalUniques));
        updateEl('cf-total-requests', formatNumber(data.totalRequests));

        // Mobile stats
        updateEl('cf-mobile-total-uniques', formatNumber(data.totalUniques));
        updateEl('cf-mobile-max-uniques', formatNumber(highestVisitorsCount.uniques));
        updateEl('cf-mobile-total-requests', formatNumber(data.totalRequests));
        updateEl('cf-mobile-total-bandwidth', totalBandwidthGB);

        // Dates
        if (data.dailyData.length > 0) {
          updateEl('cf-date-start', data.dailyData[0].date);
          updateEl('cf-date-end', data.dailyData[data.dailyData.length - 1].date);
        }

        // Chart
        const chartContainer = document.getElementById('cf-chart-container');
        if (chartContainer) {
          chartContainer.innerHTML = '';
          data.dailyData.forEach((day: any, index: number) => {
            const previousDays = data.dailyData.slice(Math.max(index - 3, 0), index);
            const drop = isDrop(
              previousDays.map((d: any) => d.uniques),
              day.uniques,
            );
            const previousDay = index > 0 ? data.dailyData[index - 1] : null;
            const isSpike = previousDay !== null && day.uniques > previousDay.uniques * 1.3;

            let classes = ['chart-bar'];
            if (index === 0) classes.push('sm:rounded-bl-xl');
            if (index === data.dailyData.length - 1) classes.push('sm:rounded-br-xl');
            if (drop) classes.push('bg-clampography-error');
            else classes.push('bg-clampography-success');

            const heightPercent = calculatePercentageOf(day.uniques, highestVisitorsCount.uniques, true);

            const div = document.createElement('div');
            div.className = classes.join(' ');
            div.style.setProperty('--bar-height', `calc(20px + ${heightPercent}%)`);
            div.title = `${day.date}\n\n${day.pageViews} page views\n${day.uniques} unique visitors`;

            if (isSpike) {
              const icon = document.createElement('iconify-icon');
              icon.setAttribute('icon', 'material-symbols:fitbit-arrow-upward');
              icon.setAttribute('width', '100%');
              icon.style.color = 'var(--color-clampography-background)';
              icon.style.flexShrink = '0';
              div.appendChild(icon);
            }

            chartContainer.appendChild(div);
          });
        }
      } catch (err) {
        console.error('Error fetching dynamic cloudflare stats', err);
      }
    }
  };

  initCloudflareStats();
  document.addEventListener('astro:page-load', initCloudflareStats);
</script>

<style>
  @reference "tailwindcss";
  :global(.chart-bar) {
    @apply flex flex-1 flex-col items-center sm:rounded-t-2xl;
    gap: 0.25rem;
    height: var(--bar-height);
    transition: height 0.15s ease;
  }
  :global(.chart-bar:hover) {
    height: calc(var(--bar-height) + 8px);
  }
</style>
