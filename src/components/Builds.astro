---
import Icon from '@xtreat/astro-iconify';
import HeadingWithIcon from './reusables/HeadingWithIcon.astro';

const buildTimeISO = new Date().toUTCString();

const FAKE_FAILURE_DATE = 'Sat, 14 Dec 2024 03:17:42 GMT';

const getLatestFailureDate = async () => {
  const repo = 'Avaray/dav.one';
  let page = 1;
  const perPage = 100;

  while (true) {
    const queryParams = `?branch=main&status=failure&per_page=${perPage}&page=${page}`;
    const response = await fetch(
      `https://api.github.com/repos/${repo}/actions/workflows/deploy.yml/runs${queryParams}`,
    );

    if (!response.ok) {
      throw new Error(`GitHub API error: ${response.status}`);
    }

    const data = await response.json();

    if (!data.workflow_runs || data.workflow_runs.length === 0) {
      return null;
    }

    const failureRun = data.workflow_runs.find((run: any) => run.conclusion === 'failure');

    if (failureRun) {
      return new Date(failureRun.updated_at).toUTCString();
    }

    if (data.workflow_runs.length < perPage) {
      return null;
    }

    page++;
  }
};

const isProduction = String(import.meta.env.PRODUCTION_BUILD) === 'true';

const latestFailureDate = isProduction ? FAKE_FAILURE_DATE : await getLatestFailureDate();
---

<div class='border rounded-2xl w-full lg:flex-1 p-4 select-none flex flex-col justify-between'>
  <div class='flex items-center justify-between text-clampography-text gap-4'>
    <HeadingWithIcon icon='icon-park-outline:analysis' title='Builds' level={3} />
    <a
      href='https://github.com/davelevy/dav.one/actions'
      target='_blank'
      rel='noopener noreferrer'
      title='Check GitHub Actions Status'
      class='hover:text-clampography-primary shrink-0'
    >
      <Icon icon='octicon:link-external-16' class='inline-block w-8 h-8 mb-(--spacing-md)' />
    </a>
  </div>

  <div id='times' class='flex flex-wrap flex-1 gap-x-6 gap-y-2 mt-4 content-start'>
    <div class='flex items-start gap-3 whitespace-nowrap'>
      <Icon
        icon='streamline:smiley-happy-solid'
        class='inline-block w-8 h-8 text-clampography-success shrink-0 self-center'
      />
      <div class='flex flex-col whitespace-nowrap'>
        <span class='font-bold'>Latest successful build:</span>
        <div id='build-hours' class='opacity-90'>{buildTimeISO}</div>
      </div>
    </div>
    {
      latestFailureDate && (
        <div class='flex items-start gap-3 whitespace-nowrap'>
          <Icon
            icon='streamline:smiley-crying-1-solid'
            class='inline-block w-8 h-8 text-clampography-error shrink-0 self-center'
          />
          <div class='flex flex-col whitespace-nowrap'>
            <span class='font-bold'>Latest failed build:</span>
            <span class='opacity-90'>{latestFailureDate}</span>
          </div>
        </div>
      )
    }
  </div>
</div>
